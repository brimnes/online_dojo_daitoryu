// ============================================================
// migration/schema.prisma
//
// Phase 0 — фиксация схемы БД для Online Dojo
// Цель: 1-к-1 соответствие текущей Supabase структуре.
//
// Ключевые решения:
//   - Таблица users = merged (auth.users + profiles)
//     Поле password_hash добавляется, всё остальное — 1-к-1.
//   - UUID-ы сохраняются — FK в других таблицах не меняются.
//   - Именование: camelCase в Prisma, snake_case в БД через @map.
//   - level/role/status — String (не enum), чтобы не ломать
//     существующие строки вида "6kyu", "1dan" и не добавлять
//     сложность при импорте данных.
//   - ⚠️  Спорные места помечены комментарием СПОРНО.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ────────────────────────────────────────────────────────────
// users
// Объединяет auth.users (id, email, password) + profiles (всё остальное).
// При импорте: email берётся из auth.users, остальное — из profiles.
// ────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")

  name         String
  // ⚠️ СПОРНО: level хранит строки "6kyu","5kyu"..."1dan" — в Prisma
  // проще String, чем enum (Prisma enum не может начинаться с цифры без @map).
  // Допустимые значения: 6kyu 5kyu 4kyu 3kyu 2kyu 1kyu 1dan 2dan 3dan
  level        String   @default("6kyu")
  // Допустимые значения: student teacher admin
  role         String   @default("student")
  // Допустимые значения: active inactive
  status       String   @default("active")

  selfLevel    String   @default("none") @map("self_level")
  senseiName   String   @default("")     @map("sensei_name")
  experience   String   @default("")

  joinedAt     DateTime @default(now()) @map("joined_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  // Relations
  userAccess        UserAccess[]
  examsAsStudent    Exam[]             @relation("ExamStudent")
  examsAsTeacher    Exam[]             @relation("ExamTeacher")
  lessonProgress    LessonProgress[]
  comments          Comment[]
  knowledgeComments KnowledgeComment[]
  payments          Payment[]

  @@map("users")
}


// ────────────────────────────────────────────────────────────
// months
// Статичные метаданные 12 месяцев. Меняются только через AdminPanel.
// ────────────────────────────────────────────────────────────
model Month {
  id          String  @id           // 'jan','feb',...,'dec'
  label       String                // 'Январь', 'Февраль', ...
  kanji       String?               // '一', '二', ...
  description String?
  isOpen      Boolean @default(false) @map("is_open")
  sortOrder   Int?    @map("sort_order")

  // Relations
  lessons Lesson[]

  @@map("months")
}


// ────────────────────────────────────────────────────────────
// lessons
// Уроки месяца. Видео хранится в Kinescope (video_id + video_status).
// video_url оставлен для обратной совместимости (старые записи).
// ────────────────────────────────────────────────────────────
model Lesson {
  id       String @id      // 'jan-1', 'jan-2', 'feb-1', ...
  monthId  String @map("month_id")
  num      Int
  title    String
  subtitle String?
  text     String?
  duration String?          // '18:40' — строка, не интервал
  videoUrl String? @map("video_url")

  // Kinescope поля (добавлены в 003_kinescope.sql)
  videoProvider  String? @default("kinescope") @map("video_provider")
  videoId        String? @map("video_id")
  // Допустимые значения: none uploading processing ready error
  videoStatus    String? @default("none")      @map("video_status")
  videoPosterUrl String? @map("video_poster_url")
  videoDuration  String? @map("video_duration")

  sortOrder  Int?      @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt      @map("updated_at")

  // Relations
  month          Month            @relation(fields: [monthId], references: [id])
  lessonProgress LessonProgress[]
  comments       Comment[]

  // ⚠️ СПОРНО: индекс на video_id нужен для kinescope/webhook — он ищет
  // урок по video_id. Указан явно, т.к. в 003_kinescope.sql создавался вручную.
  @@index([videoId], map: "idx_lessons_video_id")
  @@map("lessons")
}


// ────────────────────────────────────────────────────────────
// techniques
// Техники Иккаджо. principles — массив строк (TEXT[] в PostgreSQL).
// ────────────────────────────────────────────────────────────
model Technique {
  id          String   @id        // 'Ippondori', 'Shihonage', ...
  nameRu      String   @map("name_ru")
  kyu         String              // '6kyu', '4kyu', ...
  // ⚠️ СПОРНО: section хранит строки 'tachiai','idori','ushirodori','hanzahandachi'
  // (canonical keys из ikkajoSections.js). Не enum — т.к. ключи могут расширяться.
  section     String
  description String?
  // ⚠️ СПОРНО: principles — String[] (Prisma array). В PostgreSQL хранится
  // как TEXT[], в JSON варианте — как jsonb. Текущая Supabase схема использует
  // TEXT[] (principles TEXT[]). Prisma поддерживает String[] только для PostgreSQL.
  principles  String[]
  senseiQuote String?  @map("sensei_quote")
  sortOrder   Int?     @map("sort_order")

  // Relations
  mistakes TechniqueMistake[]
  videos   TechniqueVideo[]

  @@map("techniques")
}


// ────────────────────────────────────────────────────────────
// technique_mistakes
// Типичные ошибки по каждой технике.
// При обновлении: полная замена набора (DELETE + INSERT) через saveMistakes().
// ────────────────────────────────────────────────────────────
model TechniqueMistake {
  id          Int    @id @default(autoincrement())
  techniqueId String @map("technique_id")
  title       String
  description String?
  sortOrder   Int?   @map("sort_order")

  technique Technique @relation(fields: [techniqueId], references: [id], onDelete: Cascade)

  @@map("technique_mistakes")
}


// ────────────────────────────────────────────────────────────
// technique_videos
// Видео по технике. Категории: overview | details | mistakes | variations.
// video_id/video_status — аналогично lessons (Kinescope).
// ────────────────────────────────────────────────────────────
model TechniqueVideo {
  id          String @id        // 'ip-v1', 'sh-v1', ...
  techniqueId String @map("technique_id")
  // Допустимые значения: overview details mistakes variations
  category    String
  title       String
  duration    String?
  videoUrl    String? @map("video_url")

  // Kinescope поля
  videoProvider  String? @default("kinescope") @map("video_provider")
  videoId        String? @map("video_id")
  // Допустимые значения: none uploading processing ready error
  videoStatus    String? @default("none")      @map("video_status")
  videoPosterUrl String? @map("video_poster_url")

  sortOrder Int? @map("sort_order")

  technique Technique @relation(fields: [techniqueId], references: [id], onDelete: Cascade)

  @@index([videoId], map: "idx_tech_videos_video_id")
  @@map("technique_videos")
}


// ────────────────────────────────────────────────────────────
// user_access
// Оплаченные доступы. КРИТИЧНАЯ таблица — источник правды для платного контента.
// type: 'month' | 'section'
// reference: 'jan'..'dec' | 'ikkajo' | 'tachiai' | 'idori' | ...
// ────────────────────────────────────────────────────────────
model UserAccess {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  // Допустимые значения: month section
  type      String
  reference String               // 'jan','feb',...,'ikkajo','tachiai',...
  paidAt    DateTime @default(now()) @map("paid_at")
  amount    Int?                 // в рублях

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Уникальный доступ: один пользователь — один тип/reference
  @@unique([userId, type, reference], map: "user_access_user_id_type_reference_key")
  @@map("user_access")
}


// ────────────────────────────────────────────────────────────
// payments
// Журнал платежей YooKassa. Хранится для идемпотентности и аудита.
// raw_payload — полный JSON от YooKassa (для отладки).
// ────────────────────────────────────────────────────────────
model Payment {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id")       @db.Uuid
  productId          String    @map("product_id")    @db.Uuid
  productTitle       String?   @map("product_title")
  productType        String?   @map("product_type")        // 'month' | 'section'
  productReference   String?   @map("product_reference")   // 'jan', 'ikkajo', ...
  amount             Decimal?  @db.Decimal(10, 2)
  currency           String?   @default("RUB")
  // Допустимые значения: pending succeeded failed cancelled
  status             String    @default("pending")
  paymentProvider    String?   @map("payment_provider")    // 'yookassa'
  providerPaymentId  String?   @unique @map("provider_payment_id")
  paidAt             DateTime? @map("paid_at")
  // ⚠️ СПОРНО: raw_payload — Json тип Prisma, хранится как jsonb в PostgreSQL.
  // При импорте из Supabase: копируется как есть.
  rawPayload         Json?     @map("raw_payload")
  createdAt          DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  // ⚠️ СПОРНО: productId ссылается на products.id (UUID), но в Supabase
  // продукты не всегда создавались с реальными UUID-ами (mock-id вида 'p-jan').
  // Связь @relation намеренно НЕ добавлена — чтобы не ломать импорт старых записей.
  // Добавить после очистки данных: product Product @relation(...)

  @@map("payments")
}


// ────────────────────────────────────────────────────────────
// products
// Каталог продуктов. ~17 записей, почти статичные данные.
// ────────────────────────────────────────────────────────────
model Product {
  id          String  @id @default(uuid()) @db.Uuid
  // Допустимые значения: month section
  type        String
  reference   String              // 'jan','feb',...,'ikkajo','tachiai',...
  title       String
  description String?
  price       Decimal @db.Decimal(10, 2)
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int?    @map("sort_order")

  @@unique([type, reference])
  @@map("products")
}


// ────────────────────────────────────────────────────────────
// exams
// Заявки на аттестацию.
// ⚠️ ВАЖНО: В Supabase есть триггер on_exam_approved:
//   при status → 'approved' автоматически обновляется profiles.level.
//   В новой схеме этот триггер УБИРАЕТСЯ.
//   Логика переносится в API: при одобрении экзамена явно делать
//   prisma.user.update({ where: { id: exam.userId }, data: { level: exam.targetLevel } })
// ────────────────────────────────────────────────────────────
model Exam {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")    @db.Uuid
  targetLevel  String   @map("target_level")
  // Допустимые значения: pending approved rejected
  status       String   @default("pending")
  teacherId    String?  @map("teacher_id") @db.Uuid
  teacherNote  String?  @map("teacher_note")
  requestedAt  DateTime @default(now()) @map("requested_at")
  resolvedAt   DateTime? @map("resolved_at")

  student User  @relation("ExamStudent", fields: [userId],    references: [id], onDelete: Cascade)
  teacher User? @relation("ExamTeacher", fields: [teacherId], references: [id])

  @@map("exams")
}


// ────────────────────────────────────────────────────────────
// lesson_progress
// Прогресс просмотра уроков. Заполняется при отметке "просмотрено".
// ────────────────────────────────────────────────────────────
model LessonProgress {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")  @db.Uuid
  lessonId  String   @map("lesson_id")
  watched   Boolean  @default(false)
  watchedAt DateTime? @map("watched_at")

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}


// ────────────────────────────────────────────────────────────
// comments
// Комментарии учеников к урокам.
// ────────────────────────────────────────────────────────────
model Comment {
  id              Int       @id @default(autoincrement())
  lessonId        String    @map("lesson_id")
  userId          String    @map("user_id") @db.Uuid
  text            String
  status          String    @default("visible")
  parentCommentId Int?      @map("parent_comment_id")
  isAdminReply    Boolean   @default(false) @map("is_admin_reply")
  createdAt       DateTime  @default(now()) @map("created_at")

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId],   references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@map("comments")
}


// ────────────────────────────────────────────────────────────
// knowledge_items
// База знаний — статьи с видео. Управляется через AdminPanel.
// ⚠️ СПОРНО: эта таблица НЕ описана в sql-миграциях (нет DDL),
//   схема восстановлена из кода db.js и KnowledgeItemPage.jsx.
//   Перед запуском: сверить реальную схему через
//   \d knowledge_items  в psql или Supabase Table Editor.
// ────────────────────────────────────────────────────────────
model KnowledgeItem {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  subtitle      String?  @default("")
  content       String?  @default("")
  sortOrder     Int      @default(0) @map("sort_order")
  isPublished   Boolean  @default(false) @map("is_published")

  // Тег — категория статьи: история | принципы | этикет | теория | словарь | школа
  tag           String?

  // Kinescope поля (аналогично lessons / technique_videos)
  videoProvider String?  @map("video_provider")
  videoId       String?  @map("video_id")
  // Допустимые значения: none uploading processing ready error
  videoStatus   String?  @default("none") @map("video_status")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  comments KnowledgeComment[]

  @@map("knowledge_items")
}


// ────────────────────────────────────────────────────────────
// knowledge_comments
// Комментарии учеников к статьям базы знаний.
// ────────────────────────────────────────────────────────────
model KnowledgeComment {
  id              Int       @id @default(autoincrement())
  knowledgeItemId String    @map("knowledge_item_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  text            String
  status          String    @default("visible")
  parentCommentId Int?      @map("parent_comment_id")
  isAdminReply    Boolean   @default(false) @map("is_admin_reply")
  createdAt       DateTime  @default(now()) @map("created_at")

  knowledgeItem KnowledgeItem      @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId],          references: [id], onDelete: Cascade)
  parent        KnowledgeComment?  @relation("KnowledgeCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       KnowledgeComment[] @relation("KnowledgeCommentReplies")

  @@map("knowledge_comments")
}
